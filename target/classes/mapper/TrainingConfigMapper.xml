<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.focuskids.trainer.mapper.TrainingConfigMapper">

    <select id="selectActiveByType" resultType="com.focuskids.trainer.entity.TrainingConfig">
        SELECT * FROM training_config
        WHERE training_type = #{trainingType} AND is_active = 1
        ORDER BY level ASC
    </select>

</mapper>
