<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.focuskids.trainer.mapper.SysUserMapper">

    <select id="selectChildrenByParentId" resultType="com.focuskids.trainer.entity.SysUser">
        SELECT * FROM sys_user
        WHERE parent_id = #{parentId} AND deleted = 0 AND status = 1
        ORDER BY create_time DESC
    </select>

</mapper>
