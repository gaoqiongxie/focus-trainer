<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.focuskids.trainer.mapper.UserAbilityMapper">

    <select id="selectHistoryByUserId" resultType="com.focuskids.trainer.entity.UserAbility">
        SELECT * FROM user_ability
        WHERE user_id = #{userId}
        ORDER BY evaluate_date DESC
        LIMIT #{limit}
    </select>

</mapper>
